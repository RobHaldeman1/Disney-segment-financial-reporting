-- ============================================================\
-- SAMPLE QUERIES\
-- ============================================================\
\
-- 1. Total revenue by segment and quarter\
SELECT\
    s.segment_name,\
    fp.fiscal_year,\
    fp.fiscal_quarter,\
    SUM(r.amount) AS total_revenue\
FROM revenue r\
JOIN segments s        ON r.segment_id = s.segment_id\
JOIN fiscal_periods fp ON r.period_id  = fp.period_id\
GROUP BY s.segment_name, fp.fiscal_year, fp.fiscal_quarter\
ORDER BY fp.fiscal_year, fp.fiscal_quarter, s.segment_name;\
\
\
-- 2. Annual operating income by segment (Revenue minus Expenses)\
SELECT\
    s.segment_name,\
    fp.fiscal_year,\
    SUM(r.amount)                 AS total_revenue,\
    SUM(e.amount)                 AS total_expenses,\
    SUM(r.amount) - SUM(e.amount) AS operating_income\
FROM segments s\
JOIN (\
    SELECT segment_id, period_id, SUM(amount) AS amount\
    FROM revenue GROUP BY segment_id, period_id\
) r ON s.segment_id = r.segment_id\
JOIN (\
    SELECT segment_id, period_id, SUM(amount) AS amount\
    FROM operating_expenses GROUP BY segment_id, period_id\
) e ON s.segment_id = e.segment_id AND r.period_id = e.period_id\
JOIN fiscal_periods fp ON r.period_id = fp.period_id\
GROUP BY s.segment_name, fp.fiscal_year\
ORDER BY fp.fiscal_year, s.segment_name;\
\
\
-- 3. Each segment's % share of total company revenue by year\
SELECT\
    s.segment_name,\
    fp.fiscal_year,\
    SUM(r.amount) AS segment_revenue,\
    ROUND(\
        SUM(r.amount) * 100.0 /\
        SUM(SUM(r.amount)) OVER (PARTITION BY fp.fiscal_year),\
    2) AS pct_of_total\
FROM revenue r\
JOIN segments s        ON r.segment_id = s.segment_id\
JOIN fiscal_periods fp ON r.period_id  = fp.period_id\
GROUP BY s.segment_name, fp.fiscal_year\
ORDER BY fp.fiscal_year, pct_of_total DESC;\
\
\
-- 4. Entertainment revenue mix: Linear vs Direct-to-Consumer trend\
SELECT\
    fp.fiscal_year,\
    fp.fiscal_quarter,\
    SUM(CASE WHEN r.revenue_type = 'Linear Networks'\
        THEN r.amount ELSE 0 END)        AS linear_revenue,\
    SUM(CASE WHEN r.revenue_type = 'Direct-to-Consumer'\
        THEN r.amount ELSE 0 END)        AS dtc_revenue,\
    SUM(CASE WHEN r.revenue_type = 'Content Sales/Licensing'\
        THEN r.amount ELSE 0 END)        AS content_revenue,\
    ROUND(\
        SUM(CASE WHEN r.revenue_type = 'Direct-to-Consumer'\
            THEN r.amount ELSE 0 END) * 100.0 /\
        SUM(r.amount),\
    2) AS dtc_pct_of_entertainment\
FROM revenue r\
JOIN segments s        ON r.segment_id = s.segment_id\
JOIN fiscal_periods fp ON r.period_id  = fp.period_id\
WHERE s.segment_name = 'Entertainment'\
GROUP BY fp.fiscal_year, fp.fiscal_quarter\
ORDER BY fp.fiscal_year, fp.fiscal_quarter;\
\
\
-- 5. Experiences seasonality: which quarter generates the most revenue\
SELECT\
    fp.fiscal_quarter,\
    ROUND(AVG(quarterly_total), 2) AS avg_quarterly_revenue,\
    MIN(quarterly_total)           AS worst_year,\
    MAX(quarterly_total)           AS best_year\
FROM (\
    SELECT\
        fp.fiscal_quarter,\
        fp.fiscal_year,\
        SUM(r.amount) AS quarterly_total\
    FROM revenue r\
    JOIN segments s        ON r.segment_id = s.segment_id\
    JOIN fiscal_periods fp ON r.period_id  = fp.period_id\
    WHERE s.segment_name = 'Experiences'\
    GROUP BY fp.fiscal_quarter, fp.fiscal_year\
) sub\
JOIN fiscal_periods fp ON sub.fiscal_quarter = fp.fiscal_quarter\
GROUP BY fp.fiscal_quarter\
ORDER BY avg_quarterly_revenue DESC;\
\
\
-- 6. Operating income margin by segment and year\
SELECT\
    s.segment_name,\
    fp.fiscal_year,\
    SUM(r.amount)                         AS total_revenue,\
    SUM(r.amount) - SUM(e.amount)         AS operating_income,\
    ROUND(\
        (SUM(r.amount) - SUM(e.amount)) * 100.0 /\
        SUM(r.amount),\
    2) AS operating_margin_pct\
FROM segments s\
JOIN (\
    SELECT segment_id, period_id, SUM(amount) AS amount\
    FROM revenue GROUP BY segment_id, period_id\
) r ON s.segment_id = r.segment_id\
JOIN (\
    SELECT segment_id, period_id, SUM(amount) AS amount\
    FROM operating_expenses GROUP BY segment_id, period_id\
) e ON s.segment_id = e.segment_id AND r.period_id = e.period_id\
JOIN fiscal_periods fp ON r.period_id = fp.period_id\
GROUP BY s.segment_name, fp.fiscal_year\
ORDER BY fp.fiscal_year, operating_margin_pct DESC; }